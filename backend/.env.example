# Azure OpenAI configuration
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_API_VERSION=2024-08-01-preview
# Deployment names (not model names) as created in Azure AI Studio
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini

# Scoring mode: "rules" (default, transparent/auditable) or "ml" (trained logistic regression demo)
SCORING_MODE=rules

# SQLite database file path (relative to backend/)
DATABASE_PATH=./app/db/banking_crm.db

# Random seed for synthetic data generation (reproducible demo data)
SEED_RANDOM_STATE=42

# Number of synthetic customers to generate
SEED_CUSTOMER_COUNT=300

# CORS origin for the frontend dev server
FRONTEND_ORIGIN=http://localhost:5173
